{
  "name": "dp-rapportering-saksbehandling-frontend",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "react-router build",
    "dev": "cross-env react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint",
    "test": "pnpm run test:vitest",
    "prepare": "husky",
    "test:vitest": "vitest run",
    "pre-commit": "lint-staged && pnpm run typecheck",
    "test:playwright": "playwright test --trace on"
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "^2.5.0",
    "@grafana/faro-web-tracing": "^2.5.0",
    "@msw/data": "^1.1.5",
    "@navikt/aksel-icons": "^8.10.4",
    "@navikt/ds-css": "^8.10.4",
    "@navikt/ds-react": "^8.10.4",
    "@navikt/oasis": "^4.1.4",
    "@portabletext/react": "^6.2.0",
    "@react-router/fs-routes": "^7.15.0",
    "@react-router/node": "^7.15.0",
    "@react-router/serve": "^7.15.0",
    "@sanity/client": "^7.22.0",
    "@sanity/types": "^5.24.0",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "groq": "^5.24.0",
    "isbot": "^5.1.40",
    "msw": "^2.14.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.0",
    "tiny-invariant": "^1.3.3",
    "tinyduration": "^3.4.1",
    "usehooks-ts": "^3.1.1",
    "uuidv7": "^1.2.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@portabletext/types": "^4.0.2",
    "@react-router/dev": "^7.15.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings 0",
      "bash -c tsc",
      "bash -c 'pnpm run lint'"
    ]
